{
    "name": "chrome-manifest-builder",
    "version": "0.1.0",
    "description": "Programmatic manifest.json builder for Chrome extensions — typed fields, permission helpers, content script config, and validation for MV3.",
    "author": "Zovo <hello@zovo.one>",
    "license": "MIT",
    "keywords": [
        "chrome-extension",
        "manifest",
        "builder",
        "config",
        "mv3",
        "validate",
        "manifest-v3",
        "browser-extension"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/theluckystrike/chrome-manifest-builder.git"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/chrome": "^0.0.260",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}
